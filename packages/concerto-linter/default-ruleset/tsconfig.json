{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",

    "outDir": "./dist",

    "declaration": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node", "jest"]
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}