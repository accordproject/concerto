{
    "compilerOptions": {
      "target": "ES2018",
      "module": "commonjs",
      "outDir": "./dist",
      "rootDir": "./",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "types": ["node", "mocha", "chai", "sinon"],
      "declaration": true,
      "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "test/**/*.ts", "test/null.test.ts"],
    "exclude": ["node_modules", "dist"]
  }